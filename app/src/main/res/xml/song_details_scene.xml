<?xml version="1.0" encoding="utf-8"?>
<MotionScene
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:motion="http://schemas.android.com/apk/res-auto">

    <Transition
        android:id="@+id/collapsed_expanded"
        motion:constraintSetStart="@id/collapsed"
        motion:constraintSetEnd="@id/expanded"
        motion:duration="300">

        <KeyFrameSet>

            <KeyAttribute
                motion:motionTarget="@+id/top_scrim"
                motion:framePosition="70"
                android:alpha="0" />

            <KeyAttribute
                motion:motionTarget="@+id/bottom_scrim"
                motion:framePosition="70"
                android:alpha="0" />

        </KeyFrameSet>

    </Transition>

    <ConstraintSet
        android:id="@+id/collapsed">

        <Constraint
            android:id="@+id/songArtwork"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintTop_toTopOf="parent">

            <CustomAttribute
                motion:attributeName="radius"
                motion:customDimension="8dp" />

        </Constraint>

    </ConstraintSet>

    <ConstraintSet
        android:id="@+id/expanded">

        <Constraint
            android:id="@+id/songArtwork"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            motion:layout_constraintDimensionRatio="1:1"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintEnd_toEndOf="parent"
            motion:layout_constraintTop_toTopOf="parent">

            <CustomAttribute
                motion:attributeName="radius"
                motion:customDimension="0dp" />

        </Constraint>

        <Constraint
            android:id="@+id/top_scrim"
            android:alpha="1"
            android:layout_height="48dp"
            motion:layout_constraintTop_toTopOf="@id/songArtwork"
            motion:layout_constraintStart_toStartOf="@id/songArtwork"
            motion:layout_constraintEnd_toEndOf="@id/songArtwork"
        />

        <Constraint
            android:id="@+id/bottom_scrim"
            android:alpha="1"
            android:layout_height="64dp"
            android:scaleY="-1"
            motion:layout_constraintBottom_toBottomOf="@id/songArtwork"
            motion:layout_constraintStart_toStartOf="@id/songArtwork"
            motion:layout_constraintEnd_toEndOf="@id/songArtwork"
        />

    </ConstraintSet>

</MotionScene>
